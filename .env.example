# ─── OCR Provider ───────────────────────────────────────────
# Switch between "openrouter", "gemini", "openai"
EXPO_PUBLIC_OCR_PROVIDER=openrouter

# Google Gemini — get from aistudio.google.com/apikey
# OR from console.cloud.google.com > Generative Language API > Credentials
EXPO_PUBLIC_GEMINI_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenAI — get from platform.openai.com (fallback / alternative)
EXPO_PUBLIC_OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxx

#OpenRouter — get from openrouteservice.org/dev/#/signup
EXPO_PUBLIC_OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxx

# ─── Cerebras (AI Chatbot) ───────────────────────────────────
# Get from cloud.cerebras.ai — free tier, ultra fast
EXPO_PUBLIC_CEREBRAS_API_KEY=csk-xxxxxxxxxxxxxxxxxxxx

# ─── Supabase ────────────────────────────────────────────────
# Get from supabase.com > Project Settings > API
EXPO_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxx
