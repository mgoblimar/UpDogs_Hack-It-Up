# ─── OCR Provider ───────────────────────────────────────────
# Options: "openrouter" | "gemini" | "openai"
EXPO_PUBLIC_OCR_PROVIDER=openrouter

# OpenRouter — get from openrouter.ai/keys
EXPO_PUBLIC_OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Google Gemini — get from aistudio.google.com/apikey
EXPO_PUBLIC_GEMINI_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# OpenAI — get from platform.openai.com
EXPO_PUBLIC_OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── AI Chatbot ──────────────────────────────────────────────
# Cerebras — get from cloud.cerebras.ai (free tier, ultra fast)
EXPO_PUBLIC_CEREBRAS_API_KEY=csk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Voice Input ─────────────────────────────────────────────
# Groq Whisper — get from console.groq.com (free)
EXPO_PUBLIC_GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Supabase ────────────────────────────────────────────────
# Get from supabase.com > Project Settings > API
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ─── Live News ───────────────────────────────────────────────
# Tavily — get from app.tavily.com (free: 1,000 searches/month)
EXPO_PUBLIC_TAVILY_API_KEY=tvly-dev-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Google Maps (Android) ───────────────────────────────────
# Get from console.cloud.google.com > APIs & Services > Credentials
# Enable: Maps SDK for Android
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
