{
  "expo": {
    "name": "KuryenteKo",
    "slug": "kuryenteko",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "kuryenteko",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "KuryenteKo needs access to your photos to scan your electricity bill.",
          "cameraPermission": "KuryenteKo needs access to your camera to scan your electricity bill."
        }
      ],
      "expo-web-browser",
      "expo-audio"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.kuryenteko.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F97316"
      },
      "splash": {
        "image": "./assets/splash-icon.png",
        "resizeMode": "contain",
        "backgroundColor": "#ffffff",
        "dark": {
          "image": "./assets/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#121212"
        }
      },
      "edgeToEdgeEnabled": true,
      "softwareKeyboardLayoutMode": "pan",
      "predictiveBackGestureEnabled": false,
      "package": "com.kuryenteko.app",
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyD8Kf8Dt3HENM0uO9jVvQRfUcBe8r1B9og"
        }
      }
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "f1ba8ecf-c129-4d41-a9db-62b6ab33983b"
      }
    },
    "owner": "xenix278"
  }
}
