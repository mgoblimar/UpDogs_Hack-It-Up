# ─── Dependencies ───────────────────────────────────────────
node_modules/

# ─── Environment variables (NEVER commit these) ─────────────
.env
.env.local
.env*.local
# .env.example is safe to commit — it has no real secrets

# ─── Expo ───────────────────────────────────────────────────
.expo/
dist/
web-build/
expo-env.d.ts

# ─── EAS Build ──────────────────────────────────────────────
.easignore

# ─── Native build outputs (generated by EAS / expo run) ─────
/ios
/android
.kotlin/

# ─── Certificates & signing keys ────────────────────────────
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# ─── Metro bundler ──────────────────────────────────────────
.metro-health-check*

# ─── Debug logs ─────────────────────────────────────────────
npm-debug.*
yarn-debug.*
yarn-error.*
*.log

# ─── OS files ───────────────────────────────────────────────
.DS_Store
Thumbs.db

# ─── TypeScript ─────────────────────────────────────────────
*.tsbuildinfo

# ─── Claude Code ─────────────────────────────────────────────
.claude/
